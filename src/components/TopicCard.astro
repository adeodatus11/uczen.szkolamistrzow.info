---
import { ArrowRight } from "lucide-astro";
import type { Topic } from "@data/topics";
import { sitePath } from "../lib/paths";

type Props = {
  topic: Topic;
  compact?: boolean;
};

const { topic, compact = false } = Astro.props;
---

<article class:list={["topic-card", `tone-${topic.tone}`, { compact }]}>
  <p class="eyebrow">{topic.eyebrow}</p>
  <h3><a href={sitePath(`/temat/${topic.slug}/`)}>{topic.title}</a></h3>
  <p>{topic.summary}</p>
  <a class="text-link" href={sitePath(`/temat/${topic.slug}/`)} aria-label={`Więcej informacji: ${topic.title}`}>
    Więcej informacji <ArrowRight size={18} aria-hidden="true" />
  </a>
</article>
