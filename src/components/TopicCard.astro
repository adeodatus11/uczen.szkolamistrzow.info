---
import { ArrowRight } from "lucide-astro";
import type { Topic } from "@data/topics";

type Props = {
  topic: Topic;
  compact?: boolean;
};

const { topic, compact = false } = Astro.props;
---

<article class:list={["topic-card", `tone-${topic.tone}`, { compact }]}>
  <p class="eyebrow">{topic.eyebrow}</p>
  <h3><a href={`/temat/${topic.slug}/`}>{topic.title}</a></h3>
  <p>{topic.summary}</p>
  <a class="text-link" href={`/temat/${topic.slug}/`} aria-label={`Czytaj: ${topic.title}`}>
    Czytaj odpowiedź <ArrowRight size={18} aria-hidden="true" />
  </a>
</article>
