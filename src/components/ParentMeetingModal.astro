---
import { ArrowRight, CalendarDays, X } from "lucide-astro";
import { sitePath } from "../lib/paths";
---

<dialog class="meeting-dialog" id="parent-meeting-dialog" aria-labelledby="meeting-dialog-title" aria-describedby="meeting-dialog-description">
  <button class="meeting-dialog-close" type="button" data-meeting-close aria-label="Zamknij informację o zebraniu" title="Zamknij">
    <X size={22} aria-hidden="true" />
  </button>
  <div class="meeting-dialog-layout">
    <div class="meeting-dialog-poster" aria-hidden="true">
      <div class="meeting-poster-content">
        <img src={sitePath("/assets/zsz5-logo.png")} width="490" height="390" alt="" />
        <p>Zebranie rodziców<br />klas pierwszych</p>
        <div class="meeting-poster-date"><CalendarDays size={34} /><strong>Pierwszy tydzień września</strong></div>
        <span>Dokładny termin podamy później</span>
        <b>Bardzo ważne spotkanie</b>
      </div>
    </div>
    <div class="meeting-dialog-copy">
      <p class="eyebrow">Bardzo ważna informacja dla klas pierwszych</p>
      <h2 id="meeting-dialog-title">Zebranie rodziców i opiekunów</h2>
      <p id="meeting-dialog-description">Spotkanie dotyczy rodziców i opiekunów uczniów klas pierwszych Branżowej Szkoły I stopnia oraz Technikum nr 5.</p>
      <dl class="meeting-dialog-facts">
        <div><dt>Termin</dt><dd>Pierwszy tydzień września 2026 r.</dd></div>
        <div><dt>Szczegóły</dt><dd>Dokładna data, godzina i miejsce zostaną podane później.</dd></div>
        <div><dt>Znaczenie</dt><dd>To bardzo ważne spotkanie organizacyjne.</dd></div>
      </dl>
      <p class="meeting-dialog-note">Dalsze informacje zostaną przekazane w oficjalnym komunikacie szkoły lub w VULCAN-ie.</p>
      <div class="button-row">
        <a class="button primary" data-meeting-dismiss href={sitePath("/temat/zebranie-rodzicow-2026/")}>Przeczytaj informację <ArrowRight size={18} aria-hidden="true" /></a>
      </div>
    </div>
  </div>
</dialog>

<script>
  const meetingDialog = document.querySelector<HTMLDialogElement>("#parent-meeting-dialog");
  const closeButton = meetingDialog?.querySelector<HTMLButtonElement>("[data-meeting-close]");
  const dismissLinks = meetingDialog?.querySelectorAll<HTMLElement>("[data-meeting-dismiss]");
  const storageKey = "zsz5-parent-meeting-2026-dismissed";

  const rememberDismissal = () => {
    try {
      sessionStorage.setItem(storageKey, "true");
    } catch {
      // The announcement still works when storage is unavailable.
    }
  };

  const closeMeetingDialog = () => {
    rememberDismissal();
    meetingDialog?.close();
  };

  closeButton?.addEventListener("click", closeMeetingDialog);
  dismissLinks?.forEach((link) => link.addEventListener("click", rememberDismissal));

  meetingDialog?.addEventListener("cancel", rememberDismissal);
  meetingDialog?.addEventListener("click", (event) => {
    if (event.target !== meetingDialog) return;
    const bounds = meetingDialog.getBoundingClientRect();
    const outside = event.clientX < bounds.left || event.clientX > bounds.right || event.clientY < bounds.top || event.clientY > bounds.bottom;
    if (outside) closeMeetingDialog();
  });

  let dismissed = false;
  try {
    dismissed = sessionStorage.getItem(storageKey) === "true";
  } catch {
    dismissed = false;
  }

  if (meetingDialog && !dismissed) {
    meetingDialog.showModal();
    closeButton?.focus();
  }
</script>

<style>
  .meeting-dialog {
    position: fixed;
    box-sizing: border-box;
    width: min(900px, calc(100vw - 32px));
    max-width: calc(100vw - 32px);
    max-height: calc(100dvh - 32px);
    margin: auto;
    border: 1px solid #b8c7bd;
    border-radius: 8px;
    background: var(--paper);
    padding: 0;
    color: var(--ink);
    box-shadow: 0 24px 70px rgba(12, 28, 19, 0.28);
    overflow: hidden;
  }

  .meeting-dialog::backdrop {
    background: rgba(16, 32, 23, 0.76);
  }

  .meeting-dialog-layout {
    display: grid;
    grid-template-columns: minmax(300px, 0.86fr) minmax(360px, 1.14fr);
    min-width: 0;
    min-height: 590px;
  }

  .meeting-dialog-poster,
  .meeting-dialog-copy {
    min-width: 0;
  }

  .meeting-dialog-poster {
    display: grid;
    place-items: center;
    background: #eaf3ed;
    padding: 34px;
  }

  .meeting-poster-content {
    width: 100%;
    display: grid;
    gap: 22px;
    border-top: 8px solid #0d4c2d;
    border-bottom: 8px solid #0d4c2d;
    background: #ffffff;
    padding: 34px 28px;
    color: #103826;
    text-align: center;
  }

  .meeting-poster-content > img {
    width: 132px;
    height: auto;
    margin-inline: auto;
  }

  .meeting-poster-content > p {
    margin: 0;
    font-size: 2rem;
    font-weight: 850;
    line-height: 1.04;
    text-transform: uppercase;
  }

  .meeting-poster-date {
    display: grid;
    gap: 10px;
    justify-items: center;
    border-block: 1px solid #aac3b3;
    padding-block: 20px;
  }

  .meeting-poster-date strong {
    font-size: 1.3rem;
    line-height: 1.15;
    text-transform: uppercase;
  }

  .meeting-poster-content > span {
    color: #51675b;
    font-weight: 750;
  }

  .meeting-poster-content > b {
    background: #0d4c2d;
    color: white;
    padding: 11px 12px;
    font-size: 0.95rem;
    text-transform: uppercase;
  }

  .meeting-dialog-copy {
    align-self: center;
    padding: 52px 42px 40px;
  }

  .meeting-dialog-copy h2 {
    margin-top: 8px;
    font-size: 2.15rem;
  }

  .meeting-dialog-copy > p:not(.eyebrow) {
    margin-top: 14px;
    color: var(--muted);
  }

  .meeting-dialog-close {
    position: absolute;
    z-index: 2;
    top: 14px;
    right: 14px;
    width: 42px;
    height: 42px;
    display: grid;
    place-items: center;
    border: 1px solid var(--line);
    border-radius: 50%;
    background: var(--paper);
    color: var(--ink);
    cursor: pointer;
  }

  .meeting-dialog-close:hover {
    background: var(--soft);
  }

  .meeting-dialog-close:focus-visible {
    outline: 3px solid var(--yellow);
    outline-offset: 3px;
  }

  .meeting-dialog-facts {
    margin-top: 24px;
    border-top: 1px solid var(--line);
  }

  .meeting-dialog-facts > div {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 16px;
    border-bottom: 1px solid var(--line);
    padding: 11px 0;
  }

  .meeting-dialog-facts dt {
    color: var(--muted);
  }

  .meeting-dialog-facts dd {
    margin: 0;
    font-weight: 800;
  }

  .meeting-dialog-note {
    font-size: 0.92rem;
  }

  .meeting-dialog-copy .button-row {
    margin-top: 24px;
  }

  @media (max-width: 720px) {
    .meeting-dialog {
      width: calc(100vw - 20px);
      max-width: calc(100vw - 20px);
      max-height: calc(100dvh - 20px);
      overflow-y: auto;
    }

    .meeting-dialog-layout {
      grid-template-columns: 1fr;
      min-height: 0;
    }

    .meeting-dialog-poster img {
      width: 92px;
    }

    .meeting-dialog-poster {
      padding: 18px;
    }

    .meeting-poster-content {
      gap: 13px;
      padding: 20px 18px;
    }

    .meeting-poster-content > p {
      font-size: 1.5rem;
    }

    .meeting-poster-date {
      grid-template-columns: auto 1fr;
      gap: 10px;
      align-items: center;
      justify-items: start;
      padding-block: 13px;
      text-align: left;
    }

    .meeting-poster-date strong {
      font-size: 1.05rem;
    }

    .meeting-dialog-copy {
      padding: 28px 22px 26px;
    }

    .meeting-dialog-copy h2 {
      padding-right: 34px;
      font-size: 1.7rem;
    }

    .meeting-dialog-close {
      top: 10px;
      right: 10px;
    }

    .meeting-dialog-facts > div {
      grid-template-columns: 86px 1fr;
    }
  }
</style>
