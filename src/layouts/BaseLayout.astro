---
import { Menu, Moon, Search, Sun, X } from "lucide-astro";
import { sitePath } from "../lib/paths";
import "../styles/global.css";

type Props = {
  title: string;
  description?: string;
};

const {
  title,
  description = "Praktyczny portal informacyjny dla uczniów i rodziców Zespołu Szkół Zawodowych nr 5 we Wrocławiu.",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const socialImage = new URL(sitePath("/assets/informator-logo.png"), Astro.site);
const basePath = import.meta.env.BASE_URL.replace(/\/$/, "");
const currentPath = basePath && Astro.url.pathname.startsWith(basePath)
  ? Astro.url.pathname.slice(basePath.length) || "/"
  : Astro.url.pathname;

const navItems = [
  { href: "/branzowa/", label: "Szkoła branżowa" },
  { href: "/technikum/", label: "Technikum" },
  { href: "/rodzice/", label: "Dla rodziców" },
  { href: "/oplaty/", label: "Opłaty" },
  { href: "/podreczniki/", label: "Podręczniki" },
  { href: "/pomoc/", label: "Pomoc" },
];
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      (() => {
        try {
          const savedTheme = localStorage.getItem("zsz5-theme");
          const systemDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          document.documentElement.dataset.theme = savedTheme || (systemDark ? "dark" : "light");
        } catch {
          document.documentElement.dataset.theme = "light";
        }
      })();
    </script>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#ffffff" />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <title>{title}</title>
    <link rel="icon" href={sitePath("/assets/zsz5-logo.png")} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Przejdź do treści</a>
    <header class="site-header">
      <div class="container header-inner">
        <a class="brand" href={sitePath("/")} aria-label="Strefa Ucznia ZSZ5 - strona główna">
          <img class="brand-logo" src={sitePath("/assets/informator-logo.png")} width="1460" height="700" alt="Informator Szkoły Mistrzów" />
        </a>

        <nav class="desktop-nav" aria-label="Główna nawigacja">
          {navItems.map((item) => (
            <a href={sitePath(item.href)} aria-current={currentPath === item.href ? "page" : undefined}>{item.label}</a>
          ))}
        </nav>

        <div class="header-actions">
          <button class="icon-button theme-toggle" type="button" aria-label="Włącz tryb ciemny" aria-pressed="false" title="Włącz tryb ciemny">
            <Moon class="theme-moon-icon" size={20} aria-hidden="true" />
            <Sun class="theme-sun-icon" size={20} aria-hidden="true" />
          </button>
          <a class="icon-button search-button" href={sitePath("/szukaj/")} aria-label="Szukaj w portalu" title="Szukaj">
            <Search size={21} aria-hidden="true" />
          </a>
          <button class="icon-button menu-button" type="button" aria-label="Otwórz menu" aria-expanded="false" aria-controls="mobile-menu" title="Menu">
            <Menu class="menu-open-icon" size={22} aria-hidden="true" />
            <X class="menu-close-icon" size={22} aria-hidden="true" />
          </button>
        </div>
      </div>
      <nav class="mobile-nav" id="mobile-menu" aria-label="Menu mobilne" hidden>
        <div class="container">
          <a href={sitePath("/branzowa/")}>Uczeń szkoły branżowej</a>
          <a href={sitePath("/technikum/")}>Uczeń technikum</a>
          <a href={sitePath("/rodzice/")}>Rodzic lub opiekun</a>
          <a href={sitePath("/oplaty/")}>Opłaty i ubezpieczenie</a>
          <a href={sitePath("/podreczniki/")}>Podręczniki 2026/2027</a>
          <a href={sitePath("/temat/mlegitymacja-szkolna/")}>Legitymacja w mObywatelu</a>
          <a href={sitePath("/prawa-pracownika-mlodocianego/")}>Prawa pracownika młodocianego</a>
          <a href={sitePath("/prawa-i-obowiazki/")}>Prawa i obowiązki</a>
          <a href={sitePath("/bezpieczenstwo-uczniow/")}>Bezpieczeństwo uczniów</a>
          <a href={sitePath("/pomoc-psychologiczno-pedagogiczna/")}>Pomoc psychologiczno-pedagogiczna</a>
          <a href={sitePath("/dyrekcja/")}>Dyrekcja ZSZ5</a>
          <a href={sitePath("/pomoc/")}>Pomoc i kontakt</a>
          <a href={sitePath("/zrodla/")}>Źródła i aktualność</a>
        </div>
      </nav>
    </header>

    <main id="main-content">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-grid">
        <div class="footer-school">
          <strong>Zespół Szkół Zawodowych nr 5 we Wrocławiu</strong>
          <p>ul. Jana Władysława Dawida 5, 50-527 Wrocław</p>
          <p><a href="tel:+48717986934">+48 71 798 69 34, wew. 100</a> · <a href="mailto:sekretariat.zsz5@wroclawskaedukacja.pl">sekretariat.zsz5@wroclawskaedukacja.pl</a></p>
        </div>
        <nav aria-label="Linki w stopce">
          <a href={sitePath("/oplaty/")}>Opłaty i ubezpieczenie</a>
          <a href={sitePath("/podreczniki/")}>Podręczniki 2026/2027</a>
          <a href={sitePath("/temat/mlegitymacja-szkolna/")}>Legitymacja w mObywatelu</a>
          <a href={sitePath("/prawa-pracownika-mlodocianego/")}>Prawa pracownika młodocianego</a>
          <a href={sitePath("/prawa-i-obowiazki/")}>Prawa i obowiązki</a>
          <a href={sitePath("/bezpieczenstwo-uczniow/")}>Bezpieczeństwo uczniów</a>
          <a href={sitePath("/pomoc-psychologiczno-pedagogiczna/")}>Pomoc psychologiczno-pedagogiczna</a>
          <a href={sitePath("/dyrekcja/")}>Dyrekcja ZSZ5</a>
          <a href={sitePath("/zrodla/")}>Źródła i aktualność</a>
          <a href="https://zsz5.edupage.org/" target="_blank" rel="noreferrer">Oficjalna strona szkoły</a>
          <a href="https://szef.szkolamistrzow.info/" target="_blank" rel="noreferrer">Strefa Pracodawcy</a>
        </nav>
      </div>
      <div class="container legal-note">
        <p>Portal ma charakter informacyjny. W razie różnic wiążą aktualne przepisy, statut szkoły, umowa o pracę i oficjalne komunikaty ZSZ5.</p>
        <p>Treści prawne sprawdzone 15 lipca 2026 r.</p>
      </div>
    </footer>

    <script>
      const button = document.querySelector(".menu-button");
      const menu = document.querySelector("#mobile-menu");
      const themeButton = document.querySelector<HTMLButtonElement>(".theme-toggle");
      const themeColor = document.querySelector<HTMLMetaElement>('meta[name="theme-color"]');

      const updateThemeButton = () => {
        const dark = document.documentElement.dataset.theme === "dark";
        const label = dark ? "Włącz tryb jasny" : "Włącz tryb ciemny";
        themeButton?.setAttribute("aria-pressed", String(dark));
        themeButton?.setAttribute("aria-label", label);
        themeButton?.setAttribute("title", label);
        themeColor?.setAttribute("content", dark ? "#142119" : "#ffffff");
      };

      updateThemeButton();

      themeButton?.addEventListener("click", () => {
        const nextTheme = document.documentElement.dataset.theme === "dark" ? "light" : "dark";
        document.documentElement.dataset.theme = nextTheme;
        try {
          localStorage.setItem("zsz5-theme", nextTheme);
        } catch {
          // The theme remains active even when storage is unavailable.
        }
        updateThemeButton();
      });

      button?.addEventListener("click", () => {
        const expanded = button.getAttribute("aria-expanded") === "true";
        button.setAttribute("aria-expanded", String(!expanded));
        button.setAttribute("aria-label", expanded ? "Otwórz menu" : "Zamknij menu");
        if (menu instanceof HTMLElement) menu.hidden = expanded;
        document.body.classList.toggle("menu-is-open", !expanded);
      });
    </script>
  </body>
</html>
