---
import { AlertTriangle, ArrowLeft, CheckCircle2, ChevronDown, ExternalLink } from "lucide-astro";
import SourceLinks from "@components/SourceLinks.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { topics } from "@data/topics";
import { sitePath } from "../../lib/paths";

export function getStaticPaths() {
  return topics.map((topic) => ({ params: { slug: topic.slug }, props: { topic } }));
}

const { topic } = Astro.props;
const questions = topic.questions ?? [];
const locations = topic.locations ?? [];
const resourceLinks = topic.resourceLinks ?? [];
const backHref = topic.audiences.includes("branżowa")
  ? "/branzowa/"
  : topic.audiences.includes("technikum")
    ? "/technikum/"
    : topic.audiences.includes("rodzic")
      ? "/rodzice/"
      : "/";
---

<BaseLayout title={`${topic.title} | Strefa Ucznia ZSZ5`} description={topic.summary}>
  <header class:list={["topic-hero", `tone-${topic.tone}`]}>
    <div class="container">
      <a class="text-link" href={sitePath(backHref)}><ArrowLeft size={18} aria-hidden="true" /> Wróć do przewodnika</a>
      <p class="eyebrow">{topic.eyebrow}</p>
      <h1>{topic.title}</h1>
      <p class="lead">{topic.summary}</p>
    </div>
  </header>

  <div class="container topic-layout">
    <article class="topic-content">
      {topic.important && (
        <div class:list={["callout", { danger: topic.tone === "red" }]}>
          <AlertTriangle size={25} aria-hidden="true" />
          <div><strong>Najważniejsze</strong><p>{topic.important}</p></div>
        </div>
      )}

      <h2>Najważniejsze informacje</h2>
      <ul class="answer-list">
        {topic.facts.map((fact) => <li>{fact}</li>)}
      </ul>

      {locations.length > 0 && (
        <section aria-labelledby="topic-locations-heading">
          <h2 id="topic-locations-heading">Orientacyjna lista placówek we Wrocławiu</h2>
          <ul class="answer-list">
            {locations.map((location) => <li><strong>{location.name}</strong><br />{location.address}</li>)}
          </ul>
        </section>
      )}

      <h2>Sposób postępowania</h2>
      <ul class="answer-list actions">
        {topic.actions.map((action) => <li>{action}</li>)}
      </ul>

      {resourceLinks.length > 0 && (
        <section class="topic-resources" aria-labelledby="topic-resources-heading">
          <h2 id="topic-resources-heading">Lista pracodawców</h2>
          <div class="topic-resource-list">
            {resourceLinks.map((link) => (
              <a href={link.href} target="_blank" rel="noreferrer">
                <span><strong>{link.label}</strong><small>{link.description}</small></span>
                <ExternalLink size={20} aria-hidden="true" />
              </a>
            ))}
          </div>
        </section>
      )}

      {questions.length > 0 && (
        <section class="topic-faq" aria-labelledby="topic-faq-heading">
          <h2 id="topic-faq-heading">Pytania i odpowiedzi</h2>
          <div class="faq-list">
            {questions.map((item) => (
              <details class="faq-item">
                <summary>
                  <span>{item.question}</span>
                  <ChevronDown size={21} aria-hidden="true" />
                </summary>
                <p>{item.answer}</p>
              </details>
            ))}
          </div>
        </section>
      )}

      {topic.statuteReference && <p class="statute-ref">Podstawa w statucie: {topic.statuteReference}</p>}
    </article>

    <aside class="topic-sidebar">
      <p class="eyebrow">Powiązane informacje</p>
      <nav aria-label="Skróty w odpowiedzi">
        <a href="#sources">Źródła informacji</a>
        {topic.audiences.includes("branżowa") && <a href={sitePath("/prawa-pracownika-mlodocianego/")}>Prawa pracownika w obrazach</a>}
        <a href={sitePath("/prawa-i-obowiazki/")}>Prawa i obowiązki</a>
        <a href={sitePath("/pomoc/")}>Pomoc i kontakt</a>
        <a href={sitePath("/szukaj/")}>Znajdź inny temat</a>
      </nav>
      <div class="verified-panel topic-verified">
        <CheckCircle2 size={24} aria-hidden="true" />
        <strong>Treść zweryfikowana</strong>
        <p>Stan źródeł: 16.07.2026.</p>
      </div>
    </aside>
  </div>

  <div id="sources">
    <SourceLinks ids={topic.sourceIds} />
  </div>

  <script>
    document.querySelectorAll(".faq-item summary").forEach((summary) => {
      summary.addEventListener("keydown", (event) => {
        if (!(event instanceof KeyboardEvent) || (event.key !== "Enter" && event.key !== " ")) return;
        const details = summary.closest("details");
        if (!(details instanceof HTMLDetailsElement)) return;
        event.preventDefault();
        details.open = !details.open;
      });
    });
  </script>
</BaseLayout>

<style>
  .topic-hero .text-link {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    margin-bottom: 24px;
    color: var(--muted);
    font-weight: 750;
  }

  .topic-verified {
    margin-top: 24px;
    padding: 18px;
  }

  .topic-resources {
    margin-top: 38px;
  }

  .topic-resources h2 {
    margin-top: 0;
  }

  .topic-resource-list {
    display: grid;
    gap: 12px;
    margin-top: 18px;
  }

  .topic-resource-list a {
    min-height: 92px;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 18px;
    align-items: center;
    border: 1px solid var(--line);
    border-left: 5px solid var(--green);
    border-radius: 8px;
    background: var(--paper);
    padding: 18px 20px;
    text-decoration: none;
  }

  .topic-resource-list a:hover {
    box-shadow: var(--shadow);
  }

  .topic-resource-list strong,
  .topic-resource-list small {
    display: block;
  }

  .topic-resource-list small {
    margin-top: 5px;
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.45;
  }

  .topic-resource-list svg {
    color: var(--green-dark);
  }
</style>
