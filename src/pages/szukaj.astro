---
import { Search } from "lucide-astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { topics } from "@data/topics";

const basePath = import.meta.env.BASE_URL.replace(/\/$/, "");
const topicSearchData = topics.map((topic) => ({
  title: topic.title,
  eyebrow: topic.eyebrow,
  summary: topic.summary,
  href: `/temat/${topic.slug}/`,
  search: [
    topic.title,
    topic.eyebrow,
    topic.summary,
    ...topic.facts,
    ...topic.actions,
    ...(topic.questions ?? []).flatMap((item) => [item.question, item.answer]),
    topic.audiences.includes("branżowa") ? "BS I Branżowa Szkoła I stopnia szkoła branżowa" : "",
    topic.audiences.includes("technikum") ? "T5 Technikum nr 5 technikum" : "",
  ].join(" ").toLocaleLowerCase("pl"),
}));

const extraSearchPages = [
  {
    title: "Bezpieczeństwo uczniów w ZSZ5",
    eyebrow: "Standardy Ochrony Małoletnich",
    summary: "Jak zgłosić przemoc, krzywdzenie, wykluczenie, cyberprzemoc lub hejt oraz jak szkoła reaguje na zgłoszenie.",
    href: "/bezpieczenstwo-uczniow/",
    search: "bezpieczeństwo ucznia dziecka Standardy Ochrony Małoletnich procedury przemoc krzywdzenie wykluczenie cyberprzemoc hejt poniżanie dyskryminacja nękanie Internet zgłoszenie zaufana osoba wychowawca pedagog psycholog dyrekcja dobrostan rodzic opiekun pomoc zagrożenie 112",
  },
  {
    title: "Pomoc psychologiczno-pedagogiczna",
    eyebrow: "Pomoc w szkole",
    summary: "Telefony, adresy e-mail i godziny dyżurów pedagoga, psychologa, pedagoga specjalnego i konsultanta do spraw uzależnień.",
    href: "/pomoc-psychologiczno-pedagogiczna/",
    search: "Monika Smaczny Sylwia Bokuniewicz Maria Kaszak pedagog psycholog pedagog specjalny konsultant uzależnień dyżur godziny gabinet 04 telefon 71 798 69 34 wewnętrzny 140 142 pomoc kryzys emocje godziny psychologa godziny pedagoga telefon do psychologa telefon do pedagoga",
  },
  {
    title: "Dyrekcja ZSZ5",
    eyebrow: "Pomoc i odpowiedzialność",
    summary: "Dyrektor, wicedyrektorzy i kierownik szkolenia praktycznego: zakres spraw, telefony, gabinety i adresy e-mail.",
    href: "/dyrekcja/",
    search: "Wiesław Filipiak 101 Małgorzata Kończyńska 103 Marzena Filusz 105 Maciej Najwer 106 Arkadiusz Mocarski 102 gabinet 25 amocarski@zsz5.edupage.org sekretariat 100 numer wewnętrzny telefon 71 798 69 34 dyrektor wicedyrektor sprawy wychowawcze dydaktyczne organizacja nauczania bezpieczeństwo skarga kierownik szkolenia praktycznego praktyki zawodowe zajęcia praktyczne pracodawca umowa pracownik młodociany zmiana pracodawcy wicedyrektor wychowawczy wicedyrektor dydaktyczny wicedyrektor do spraw dydaktycznych wicedyrektor do spraw wychowawczych",
  },
  {
    title: "Opłaty i ubezpieczenie",
    eyebrow: "Dane archiwalne 2025/2026",
    summary: "Kwoty Rady Rodziców, monitoring, materiały kserograficzne, dzienniczek zajęć praktycznych i ubezpieczenie NNW. Dane wymagają aktualizacji.",
    href: "/oplaty/",
    search: "Rada Rodziców 60 zł drugie dziecko 30 zł monitoring 15 zł materiały kserograficzne ksero 15 zł dzienniczek zajęć praktycznych 10 zł TUZ ubezpieczenie NNW 67 zł suma ubezpieczenia 26000 26 000 Santander konto rachunek opłaty składki 2025 2026",
  },
].map((page) => ({ ...page, search: [page.title, page.eyebrow, page.summary, page.search].join(" ").toLocaleLowerCase("pl") }));

const searchData = [...topicSearchData, ...extraSearchPages];
---

<BaseLayout title="Wyszukiwarka informacji | Strefa Ucznia ZSZ5" description="Wyszukiwarka informacji dla uczniów i rodziców ZSZ5.">
  <section class="page-hero search-page">
    <div class="container">
      <p class="eyebrow">Baza wiedzy</p>
      <h1>Wyszukiwarka informacji</h1>
      <p class="lead">Wpisz nazwę sprawy, na przykład: urlop, zwolnienie lekarskie, praktyki, umowa, wynagrodzenie lub oceny.</p>
      <form class="search-field" role="search" id="search-form">
        <label class="sr-only" for="portal-search">Wpisz szukany temat</label>
        <input id="portal-search" type="search" name="q" placeholder="Wpisz temat" autocomplete="off" />
        <button type="submit" aria-label="Szukaj"><Search size={22} aria-hidden="true" /></button>
      </form>
      <p class="search-meta" id="search-meta" aria-live="polite">Wpisz co najmniej 2 znaki.</p>
      <div class="search-results" id="search-results"></div>
      <noscript><p class="empty-state">Wyszukiwarka wymaga JavaScript. Skorzystaj z menu Szkoła branżowa, Technikum lub Prawa i obowiązki.</p></noscript>
    </div>
  </section>

  <script is:inline type="application/json" id="topics-data" set:html={JSON.stringify({ basePath, topics: searchData }).replaceAll("<", "\\u003c")}></script>
  <script>
    type SearchItem = {
      title: string;
      eyebrow: string;
      summary: string;
      href: string;
      search: string;
    };

    const dataElement = document.querySelector("#topics-data");
    const input = document.querySelector("#portal-search");
    const form = document.querySelector("#search-form");
    const results = document.querySelector("#search-results");
    const meta = document.querySelector("#search-meta");
    const payload: { basePath: string; topics: SearchItem[] } = dataElement?.textContent
      ? JSON.parse(dataElement.textContent)
      : { basePath: "", topics: [] };
    const data = payload.topics;

    const entities: Record<string, string> = {
      "&": "&amp;", "<": "&lt;", ">": "&gt;", "'": "&#39;", '"': "&quot;",
    };
    const escapeHtml = (value: string) => value.replace(/[&<>'"]/g, (char) => entities[char]);

    const render = (rawQuery: string) => {
      if (!(results instanceof HTMLElement) || !(meta instanceof HTMLElement)) return;
      const query = rawQuery.trim().toLocaleLowerCase("pl");
      const url = new URL(window.location.href);

      if (query) url.searchParams.set("q", rawQuery.trim());
      else url.searchParams.delete("q");
      window.history.replaceState({}, "", url);

      if (query.length < 2) {
        results.innerHTML = "";
        meta.textContent = "Wpisz co najmniej 2 znaki.";
        return;
      }

      const matches = data.filter((item) => item.search.includes(query));
      meta.textContent = matches.length === 1 ? "Znaleziono 1 odpowiedź." : `Znaleziono ${matches.length} odpowiedzi.`;

      if (!matches.length) {
        results.innerHTML = '<div class="empty-state"><strong>Brak wyników.</strong><p>Spróbuj krótszego hasła albo przejdź do strony Pomoc i kontakt.</p></div>';
        return;
      }

      results.innerHTML = matches.map((item) => `
        <a class="search-result" href="${payload.basePath}${escapeHtml(item.href)}">
          <span><small class="eyebrow">${escapeHtml(item.eyebrow)}</small><strong>${escapeHtml(item.title)}</strong><p>${escapeHtml(item.summary)}</p></span>
          <span aria-hidden="true">→</span>
        </a>
      `).join("");
    };

    form?.addEventListener("submit", (event) => {
      event.preventDefault();
      if (input instanceof HTMLInputElement) render(input.value);
    });

    input?.addEventListener("input", () => {
      if (input instanceof HTMLInputElement) render(input.value);
    });

    const initial = new URL(window.location.href).searchParams.get("q") ?? "";
    if (input instanceof HTMLInputElement) {
      input.value = initial;
      if (initial) render(initial);
      input.focus();
    }
  </script>
</BaseLayout>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
  }
</style>
