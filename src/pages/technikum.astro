---
import { ArrowRight, CalendarDays, ClipboardCheck } from "lucide-astro";
import AudienceHero from "@components/AudienceHero.astro";
import StartNotices from "@components/StartNotices.astro";
import TopicCard from "@components/TopicCard.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { topicsFor } from "@data/topics";
import { sitePath } from "../lib/paths";

const sectionTopics = topicsFor("technikum").filter((topic) => topic.slug !== "pierwszy-tydzien");
---

<BaseLayout title="Uczeń Technikum nr 5 | Strefa Ucznia ZSZ5" description="Przewodnik dla ucznia Technikum nr 5: organizacja nauki, praktyki zawodowe, nieobecności, prawa, obowiązki i pomoc.">
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Technikum nr 5 im. Jana Kilińskiego (T5)</p>
      <h1>Nauka, praktyki i egzaminy w technikum</h1>
      <p class="lead">Technikum łączy przedmioty ogólne i zawodowe. Praktyki są częścią programu, a egzaminy zawodowe i matura to dwa odrębne cele.</p>
      <div class="button-row">
        <a class="button primary" href={sitePath("/temat/jak-dziala-technikum/")}>Organizacja nauki w technikum <ArrowRight size={18} aria-hidden="true" /></a>
        <a class="button" href={sitePath("/temat/praktyki-technikum/")}><ClipboardCheck size={18} aria-hidden="true" /> Praktyki zawodowe</a>
      </div>
    </div>
  </section>

  <section class="band start-band" aria-labelledby="t5-start-dates">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Początek roku szkolnego 2026/2027</p>
        <h2 id="t5-start-dates">Terminy ucznia klasy pierwszej technikum</h2>
        <p>Zaświadczenie lekarskie, zebranie rodziców i karta zdrowia dotyczą obu typów szkoły. Termin umowy o pracę dotyczy wyłącznie uczniów szkoły branżowej.</p>
      </div>
      <StartNotices show="common" />
    </div>
  </section>

  <section class="band band-soft">
    <div class="container">
      <AudienceHero current="technikum" />
    </div>
  </section>

  <section class="band">
    <div class="container">
      <div class="callout">
        <CalendarDays size={26} aria-hidden="true" />
        <div>
          <h2>Praktyki zawodowe a zatrudnienie</h2>
          <p>Uczeń technikum nie jest automatycznie pracownikiem młodocianym. Harmonogram praktyk i egzaminów zależy od klasy, zawodu i roku szkolnego; konkretne daty sprawdzaj w VULCAN-ie i komunikatach szkoły.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="band" aria-labelledby="t5-topics">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Przewodnik ucznia technikum</p>
        <h2 id="t5-topics">Najważniejsze informacje dla ucznia technikum</h2>
        <p>Informacje dotyczą organizacji nauki, praktyk zawodowych, nieobecności i egzaminów.</p>
      </div>
      <div class="topic-grid">
        {sectionTopics.map((topic) => <TopicCard topic={topic} compact />)}
      </div>
    </div>
  </section>
</BaseLayout>
