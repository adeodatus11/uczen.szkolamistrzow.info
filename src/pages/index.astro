---
import { ArrowRight, CheckCircle2, Search, ShieldAlert } from "lucide-astro";
import AudienceHero from "@components/AudienceHero.astro";
import TopicCard from "@components/TopicCard.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { topics } from "@data/topics";
import { sitePath } from "../lib/paths";

const featuredSlugs = [
  "vulcan",
  "mlodociany-pracownik",
  "czas-pracy",
  "urlop-mlodocianego",
  "praktyki-technikum",
  "nieobecnosc-technikum",
];
const featured = featuredSlugs.map((slug) => topics.find((topic) => topic.slug === slug)).filter(Boolean);
---

<BaseLayout title="Strefa Ucznia ZSZ5 - szkoła, zawód i praca">
  <section class="page-hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Szkoła · zawód · praca</p>
        <h1>W ZSZ5 wiesz, co robić dalej</h1>
        <p>
          Krótkie odpowiedzi dla nowych uczniów i rodziców. Osobno dla Branżowej Szkoły I stopnia,
          Technikum nr 5 i spraw wspólnych: prawa, obowiązki, frekwencja, praktyki i pomoc.
        </p>
        <form class="hero-search" action={sitePath("/szukaj/")} method="get" role="search">
          <label class="sr-only" for="home-search">Szukaj odpowiedzi</label>
          <input id="home-search" name="q" type="search" placeholder="Wpisz temat, np. urlop, L4, praktyki" autocomplete="off" />
          <button type="submit" aria-label="Szukaj"><Search size={22} aria-hidden="true" /></button>
        </form>
      </div>
      <aside class="verified-panel">
        <CheckCircle2 size={28} aria-hidden="true" />
        <strong>Informacje oparte na aktualnych źródłach</strong>
        <p>Statut ZSZ5 obowiązujący od 16.10.2025, Kodeks pracy, PIP, MEN i akty w ELI.</p>
        <a href={sitePath("/zrodla/")}>Zobacz źródła i daty weryfikacji</a>
      </aside>
    </div>
  </section>

  <section class="band band-soft" aria-labelledby="choose-path">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Zacznij tutaj</p>
        <h2 id="choose-path">Która ścieżka dotyczy Ciebie?</h2>
        <p>Nie musisz czytać całego portalu. Wybierz rolę, a pokażemy najważniejsze sprawy w dobrej kolejności.</p>
      </div>
      <AudienceHero />
    </div>
  </section>

  <section class="band" aria-labelledby="popular-topics">
    <div class="container">
      <div class="section-heading wide">
        <div>
          <p class="eyebrow">Najczęstsze pytania</p>
          <h2 id="popular-topics">Odpowiedzi potrzebne od początku</h2>
          <p>Każdy temat kończy się konkretną listą działań i linkami do źródeł.</p>
        </div>
        <a class="button" href={sitePath("/szukaj/")}>Wszystkie tematy <ArrowRight size={18} aria-hidden="true" /></a>
      </div>
      <div class="topic-grid">
        {featured.map((topic) => topic && <TopicCard topic={topic} />)}
      </div>
    </div>
  </section>

  <section class="band band-dark" aria-labelledby="first-week">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Pierwszy tydzień</p>
        <h2 id="first-week">Cztery rzeczy do uporządkowania</h2>
      </div>
      <ol class="steps">
        <li><strong>Uruchom VULCAN</strong><span>Uczeń i rodzic sprawdzają osobne konta oraz wiadomości.</span></li>
        <li><strong>Poznaj swój plan</strong><span>Lekcje, dni u pracodawcy albo termin praktyk.</span></li>
        <li><strong>Zapisz kontakty</strong><span>Wychowawca, sekretariat i osoba od kształcenia praktycznego.</span></li>
        <li><strong>Sprawdź dokumenty</strong><span>Statut, umowa BS I, badania, BHP lub dokumenty praktyk T5.</span></li>
      </ol>
    </div>
  </section>

  <section class="band" aria-labelledby="danger-help">
    <div class="container">
      <div class="callout danger">
        <ShieldAlert size={28} aria-hidden="true" />
        <div>
          <h2 id="danger-help">Gdy zagrożone jest zdrowie lub bezpieczeństwo</h2>
          <p>Przerwij niebezpieczną czynność, odejdź w bezpieczne miejsce i powiadom osobę dorosłą. W sytuacji nagłej dzwoń pod 112.</p>
          <div class="button-row">
            <a class="button" href={sitePath("/temat/bhp-i-wypadek/")}>BHP i wypadek</a>
            <a class="button" href={sitePath("/pomoc/")}>Pomoc i kontakt</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
  }
</style>
