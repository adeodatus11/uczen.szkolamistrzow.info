---
import { ArrowRight, CheckCircle2, Clock3, Search, ShieldAlert } from "lucide-astro";
import AudienceHero from "@components/AudienceHero.astro";
import PathComparison from "@components/PathComparison.astro";
import StartNotices from "@components/StartNotices.astro";
import TopicCard from "@components/TopicCard.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { topics } from "@data/topics";
import { sitePath } from "../lib/paths";

const featuredSlugs = [
  "vulcan",
  "mlegitymacja-szkolna",
  "mlodociany-pracownik",
  "czas-pracy",
  "urlop-mlodocianego",
  "praktyki-technikum",
];
const featured = featuredSlugs.map((slug) => topics.find((topic) => topic.slug === slug)).filter(Boolean);
---

<BaseLayout title="Strefa Ucznia ZSZ5 - szkoła, zawód i praca">
  <section class="page-hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Szkoła · zawód · praca</p>
        <h1>Strefa Ucznia Szkoły Mistrzów</h1>
        <p>
          Najważniejsze informacje dla osób rozpoczynających naukę w Branżowej Szkole I stopnia
          lub Technikum nr 5 oraz dla ich rodziców i opiekunów.
        </p>
        <form class="hero-search" action={sitePath("/szukaj/")} method="get" role="search">
          <label class="sr-only" for="home-search">Szukaj informacji</label>
          <input id="home-search" name="q" type="search" placeholder="Wpisz temat, np. urlop, zwolnienie, praktyki" autocomplete="off" />
          <button type="submit" aria-label="Szukaj"><Search size={22} aria-hidden="true" /></button>
        </form>
      </div>
      <aside class="start-dashboard" aria-label="Najważniejsze terminy na początek roku szkolnego">
        <h2>Najważniejsze terminy</h2>
        <ol class="dashboard-dates">
          <li>
            <time datetime="2026-08-20"><strong>20</strong><span>sie</span></time>
            <div><strong>Umowa ucznia szkoły branżowej</strong><p>Do weryfikacji w gabinecie 25 u p. Arkadiusza Mocarskiego.</p></div>
          </li>
          <li>
            <time datetime="2026-09-02T16:00"><strong>2</strong><span>wrz</span></time>
            <div><strong>Zebranie rodziców klas pierwszych</strong><p><Clock3 size={15} aria-hidden="true" /> 16:00 · obecność obowiązkowa.</p></div>
          </li>
          <li>
            <time datetime="2026-09-30"><strong>30</strong><span>wrz</span></time>
            <div><strong>Karta zdrowia</strong><p>Najpóźniej do końca września.</p></div>
          </li>
        </ol>
        <div class="dashboard-source">
          <CheckCircle2 size={19} aria-hidden="true" />
          <a href={sitePath("/zrodla/")}>Źródła i daty weryfikacji informacji</a>
        </div>
      </aside>
    </div>
  </section>

  <section class="band start-band" aria-labelledby="start-dates">
    <div class="container">
      <div class="section-heading wide">
        <div>
          <p class="eyebrow">Początek roku szkolnego 2026/2027</p>
          <h2 id="start-dates">Trzy terminy dla nowych uczniów i rodziców</h2>
          <p>Pierwszy termin dotyczy wyłącznie uczniów szkoły branżowej. Dwa wrześniowe dotyczą klas pierwszych obu typów szkół.</p>
        </div>
        <a class="button" href={sitePath("/rodzice/")}>Informacje dla rodziców <ArrowRight size={18} aria-hidden="true" /></a>
      </div>
      <StartNotices />
    </div>
  </section>

  <section class="band band-soft" aria-labelledby="choose-path">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Wybór zakresu informacji</p>
        <h2 id="choose-path">Wybierz typ szkoły lub rolę</h2>
        <p>Informacje są uporządkowane osobno dla uczniów szkoły branżowej, uczniów technikum oraz rodziców i opiekunów.</p>
      </div>
      <AudienceHero />
    </div>
  </section>

  <section class="band" aria-labelledby="compare-paths">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Porównanie typów szkoły</p>
        <h2 id="compare-paths">Branżowa Szkoła I stopnia i technikum</h2>
        <p>Uczeń szkoły branżowej jest jednocześnie uczniem i pracownikiem młodocianym. Uczeń technikum pozostaje uczniem, a praktyki realizuje w ramach programu szkoły.</p>
      </div>
      <dl class="school-type-definitions">
        <div>
          <dt>Branżowa Szkoła I stopnia nr 5 <span>BS I</span></dt>
          <dd>W portalu używamy też krótszej nazwy „szkoła branżowa”. Jej uczeń pracuje u pracodawcy jako pracownik młodociany na podstawie umowy o pracę.</dd>
        </div>
        <div>
          <dt>Technikum nr 5 <span>T5</span></dt>
          <dd>W portalu używamy najczęściej nazwy „technikum”. Praktyki zawodowe są częścią programu szkoły i same nie oznaczają zatrudnienia.</dd>
        </div>
      </dl>
      <p class="school-type-help">Jeżeli nie wiesz, który przewodnik wybrać, sprawdź pełną nazwę szkoły w potwierdzeniu przyjęcia lub w VULCAN-ie.</p>
      <PathComparison />
    </div>
  </section>

  <section class="band" aria-labelledby="popular-topics">
    <div class="container">
      <div class="section-heading wide">
        <div>
          <p class="eyebrow">Najczęstsze pytania</p>
          <h2 id="popular-topics">Najważniejsze informacje na początku nauki</h2>
          <p>Każdy temat zawiera wyjaśnienie, sposób postępowania i odnośniki do źródeł.</p>
        </div>
        <a class="button" href={sitePath("/szukaj/")}>Wszystkie tematy <ArrowRight size={18} aria-hidden="true" /></a>
      </div>
      <div class="topic-grid">
        {featured.map((topic) => topic && <TopicCard topic={topic} />)}
      </div>
    </div>
  </section>

  <section class="band band-dark" aria-labelledby="first-week">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Początek roku szkolnego</p>
        <h2 id="first-week">Cztery sprawy do sprawdzenia</h2>
      </div>
      <ol class="steps">
        <li><strong>Uruchom VULCAN</strong><span>Uczeń i rodzic sprawdzają osobne konta oraz wiadomości.</span></li>
        <li><strong>Poznaj swój plan</strong><span>Lekcje, dni u pracodawcy albo termin praktyk.</span></li>
        <li><strong>Zapisz kontakty</strong><span>Wychowawca, sekretariat i osoba od kształcenia praktycznego.</span></li>
        <li><strong>Sprawdź dokumenty</strong><span>Statut, umowa ucznia szkoły branżowej, badania, BHP lub dokumenty praktyk w technikum.</span></li>
      </ol>
    </div>
  </section>

  <section class="band" aria-labelledby="danger-help">
    <div class="container">
      <div class="callout danger">
        <ShieldAlert size={28} aria-hidden="true" />
        <div>
          <h2 id="danger-help">Gdy zagrożone jest zdrowie lub bezpieczeństwo</h2>
          <p>Przerwij niebezpieczną czynność, odejdź w bezpieczne miejsce i powiadom osobę dorosłą. W sytuacji nagłej dzwoń pod 112.</p>
          <div class="button-row">
            <a class="button" href={sitePath("/temat/bhp-i-wypadek/")}>BHP i wypadek</a>
            <a class="button" href={sitePath("/pomoc/")}>Pomoc i kontakt</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
  }
</style>
