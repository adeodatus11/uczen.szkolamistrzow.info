---
import { AlertTriangle, ArrowRight, FileText } from "lucide-astro";
import AudienceHero from "@components/AudienceHero.astro";
import PathComparison from "@components/PathComparison.astro";
import StartNotices from "@components/StartNotices.astro";
import TopicCard from "@components/TopicCard.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { topicsFor } from "@data/topics";
import { sitePath } from "../lib/paths";

const sectionTopics = topicsFor("branżowa").filter((topic) => topic.slug !== "pierwszy-tydzien");
---

<BaseLayout title="Uczeń szkoły branżowej - pracownik młodociany | Strefa Ucznia ZSZ5" description="Przewodnik dla ucznia Branżowej Szkoły I stopnia nr 5: umowa, czas pracy, wynagrodzenie, urlop, BHP, nieobecności i zmiana pracodawcy.">
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Branżowa Szkoła I stopnia nr 5 (BS I)</p>
      <h1>Uczeń szkoły branżowej i pracownik młodociany</h1>
      <p class="lead">Uczeń Branżowej Szkoły I stopnia uczy się w szkole i odbywa przygotowanie zawodowe u pracodawcy. Obowiązują go zarówno prawa i obowiązki ucznia, jak i przepisy prawa pracy.</p>
      <div class="button-row">
        <a class="button primary" href={sitePath("/temat/mlodociany-pracownik/")}>Status pracownika młodocianego <ArrowRight size={18} aria-hidden="true" /></a>
        <a class="button" href={sitePath("/temat/umowa-o-prace/")}><FileText size={18} aria-hidden="true" /> Informacje o umowie</a>
      </div>
    </div>
  </section>

  <section class="band start-band" aria-labelledby="bs-start-dates">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Początek roku szkolnego 2026/2027</p>
        <h2 id="bs-start-dates">Terminy ucznia klasy pierwszej szkoły branżowej</h2>
      </div>
      <StartNotices show="bs" />
    </div>
  </section>

  <section class="band" aria-labelledby="bs-recruitment">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Kandydat do szkoły branżowej</p>
        <h2 id="bs-recruitment">Najpierw rekrutacja i pracodawca</h2>
        <p>Jeżeli dopiero poznajesz ZSZ5, zacznij od przewodnika rekrutacyjnego na stronie Szkoły Mistrzów. Kandydat do Branżowej Szkoły I stopnia musi znaleźć pracodawcę uprawnionego do prowadzenia przygotowania zawodowego i podpisać z nim umowę o pracę. Bez tej umowy nie może rozpocząć nauki jako pracownik młodociany. Umowę trzeba przekazać szkole do weryfikacji najpóźniej 20 sierpnia 2026 r.</p>
      </div>
      <div class="quick-link-grid">
        <a class="quick-link" href="https://www.szkolamistrzow.info/rekrutacja.html" target="_blank" rel="noreferrer"><strong>Przewodnik rekrutacyjny</strong><span>Etapy rekrutacji, terminy, dokumenty i badania</span><ArrowRight size={20} aria-hidden="true" /></a>
        <a class="quick-link" href="https://www.szkolamistrzow.info/pracodawcy.html" target="_blank" rel="noreferrer"><strong>Pracodawcy i cechy</strong><span>Firmy i kontakty uporządkowane według zawodów</span><ArrowRight size={20} aria-hidden="true" /></a>
      </div>
    </div>
  </section>

  <section class="band band-soft">
    <div class="container">
      <AudienceHero current="branżowa" />
    </div>
  </section>

  <section class="band band-soft" aria-labelledby="bs-vs-t5">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Status ucznia szkoły branżowej</p>
        <h2 id="bs-vs-t5">Umowa o pracę ucznia szkoły branżowej</h2>
        <p>Umowa o pracę odróżnia przygotowanie zawodowe pracownika młodocianego od praktyki zawodowej ucznia technikum.</p>
      </div>
      <PathComparison />
    </div>
  </section>

  <section class="band">
    <div class="container">
      <div class="callout">
        <AlertTriangle size={26} aria-hidden="true" />
        <div>
          <h2>Nieobecność w szkole i w pracy</h2>
          <p>Nieobecność w szkole i nieobecność w pracy zgłasza się osobno. Ferie szkolne także nie są automatycznie urlopem od pracy.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="band" aria-labelledby="bs-topics">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Przewodnik ucznia szkoły branżowej</p>
        <h2 id="bs-topics">Najważniejsze informacje dla ucznia szkoły branżowej</h2>
        <p>Każdy temat zawiera wyjaśnienie, sposób postępowania i odnośniki do źródeł.</p>
      </div>
      <div class="topic-grid">
        {sectionTopics.map((topic) => <TopicCard topic={topic} compact />)}
      </div>
    </div>
  </section>
</BaseLayout>
