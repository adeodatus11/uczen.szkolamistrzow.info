---
import { AlertTriangle, ArrowRight, FileText } from "lucide-astro";
import AudienceHero from "@components/AudienceHero.astro";
import PathComparison from "@components/PathComparison.astro";
import StartNotices from "@components/StartNotices.astro";
import TopicCard from "@components/TopicCard.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { topicsFor } from "@data/topics";
import { sitePath } from "../lib/paths";

const sectionTopics = topicsFor("branżowa").filter((topic) => topic.slug !== "pierwszy-tydzien");
---

<BaseLayout title="Uczeń BS I - młodociany pracownik | Strefa Ucznia ZSZ5" description="Przewodnik dla ucznia Branżowej Szkoły I stopnia nr 5: umowa, czas pracy, wynagrodzenie, urlop, BHP, nieobecności i zmiana pracodawcy.">
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Branżowa Szkoła I stopnia nr 5</p>
      <h1>Uczeń BS I jako pracownik młodociany</h1>
      <p class="lead">Uczeń BS I uczy się w szkole i odbywa przygotowanie zawodowe u pracodawcy. Obowiązują go zarówno prawa i obowiązki ucznia, jak i przepisy prawa pracy.</p>
      <div class="button-row">
        <a class="button primary" href={sitePath("/temat/mlodociany-pracownik/")}>Status pracownika młodocianego <ArrowRight size={18} aria-hidden="true" /></a>
        <a class="button" href={sitePath("/temat/umowa-o-prace/")}><FileText size={18} aria-hidden="true" /> Informacje o umowie</a>
      </div>
    </div>
  </section>

  <section class="band start-band" aria-labelledby="bs-start-dates">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Początek roku szkolnego 2026/2027</p>
        <h2 id="bs-start-dates">Terminy ucznia klasy pierwszej BS I</h2>
      </div>
      <StartNotices show="bs" />
    </div>
  </section>

  <section class="band band-soft">
    <div class="container">
      <AudienceHero current="branżowa" />
    </div>
  </section>

  <section class="band band-soft" aria-labelledby="bs-vs-t5">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Status ucznia BS I</p>
        <h2 id="bs-vs-t5">Umowa o pracę w BS I</h2>
        <p>Umowa o pracę odróżnia przygotowanie zawodowe pracownika młodocianego od praktyki zawodowej ucznia technikum.</p>
      </div>
      <PathComparison />
    </div>
  </section>

  <section class="band">
    <div class="container">
      <div class="callout">
        <AlertTriangle size={26} aria-hidden="true" />
        <div>
          <h2>Nieobecność w szkole i w pracy</h2>
          <p>Nieobecność w szkole i nieobecność w pracy zgłasza się osobno. Ferie szkolne także nie są automatycznie urlopem od pracy.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="band" aria-labelledby="bs-topics">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Przewodnik BS I</p>
        <h2 id="bs-topics">Najważniejsze informacje dla ucznia BS I</h2>
        <p>Każdy temat zawiera wyjaśnienie, sposób postępowania i odnośniki do źródeł.</p>
      </div>
      <div class="topic-grid">
        {sectionTopics.map((topic) => <TopicCard topic={topic} compact />)}
      </div>
    </div>
  </section>
</BaseLayout>
